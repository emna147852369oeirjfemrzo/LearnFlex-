{# templates/front/organismes.html.twig #}

{% extends 'front/home.html.twig' %}

{% block title %}Organismes - LearnFlex+{% endblock %}

{% block header %}
<header class="landing-header">
    <div class="container">
        <div class="header-left">
            <div class="logo">
                <img src="{{ asset('assets/images/logo1.png') }}" alt="LearnFlex+ Logo" class="main-logo">
                <span class="logo-text">LearnFlex +</span>
            </div>
        </div>
        <nav class="main-nav">
            <ul>
                <li class="active"><a href="{{ path('app_front') }}">Accueil</a></li>
                <li><a href="#">Contenus pédagogiques</a></li>
                <li><a href="#">Evaluation</a></li>
                <li><a href="#">Questionnaire</a></li>
                <li><a href="{{ path('front_evenements') }}">Orientation</a></li>
                <li><a href="#">Forum</a></li>
            </ul>
        </nav>
        <div class="header-right">
            {% if app.user and app.user.type != 'client' %}
                <a href="#" class="btn btn-outline dashboard-btn">Dashboard</a>
            {% endif %}
            {% if app.user %}
                <a href="#" class="btn btn-primary logout-btn">Déconnexion</a>
            {% else %}
                <a href="#" class="btn btn-primary">Connexion</a>
            {% endif %}
            <button class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </div>
</header>
{% endblock %}

{% block body %}
<a href="{{ path('app_front') }}" class="btn-back-home">
    Retour vers Accueil
</a>

<main>
    <section class="organismes-section">
        <div class="container">
            <div class="section-header">
                <span class="badge-section">Partenaires</span>
                <h1>Organismes disponibles</h1>
                <p>Découvrez les établissements et partenaires qui proposent formations et événements.</p>
            </div>

            <div class="organismes-grid">
                {% for organisme in organismes %}
                    {% set siteUrl = organisme.siteweb and organisme.siteweb|trim != '' ? ((organisme.siteweb starts with 'http://') or (organisme.siteweb starts with 'https://') ? organisme.siteweb : 'https://' ~ organisme.siteweb) : null %}
                    <article class="organisme-card">
                        <a href="{{ path('front_organisme_show', {'id': organisme.id}) }}">
                            <div class="organisme-photo">
                                {% if organisme.photo %}
                                    <img src="{{ asset('uploads/organismes/' ~ organisme.photo) }}" alt="{{ organisme.nom }}">
                                {% else %}
                                    <div class="organisme-placeholder"><i class="fas fa-building"></i></div>
                                {% endif %}
                            </div>
                            <div class="organisme-body">
                                <h3>{{ organisme.nom }}</h3>
                                {% if organisme.type %}<span class="organisme-type">{{ organisme.type }}</span>{% endif %}
                                {% if organisme.description %}<p class="organisme-description">{{ organisme.description }}</p>{% endif %}
                                {% if organisme.ville %}<p class="organisme-ville"><i class="fas fa-map-marker-alt"></i> {{ organisme.ville }}</p>{% endif %}
                                {% if organisme.langue %}<p class="organisme-langue">Langue: {{ organisme.langue }}</p>{% endif %}
                                {% if organisme.fraismin %}<p class="organisme-frais">Frais min.: {{ organisme.fraismin }} DT</p>{% endif %}
                                <p class="organisme-status {% if organisme.actif %}active{% else %}inactive{% endif %}">Statut: {{ organisme.actif ? 'Actif' : 'Inactif' }}</p>
                                {% if organisme.opportunitesstage %}<p class="opportunites">Opportunités stage: Oui</p>{% endif %}
                                {% if organisme.opportunitesemploi %}<p class="opportunites">Opportunités emploi: Oui</p>{% endif %}
                            </div>
                        </a>
                        {% if siteUrl %}
                            <div class="organisme-footer">
                                <a href="{{ siteUrl }}" target="_blank" rel="noopener noreferrer" class="btn-visiter-site">
                                    <i class="fas fa-external-link-alt"></i> Visiter le site
                                </a>
                            </div>
                        {% endif %}
                    </article>
                {% else %}
                    <div class="no-organismes">
                        <i class="fas fa-inbox"></i>
                        <p>Aucun organisme disponible pour le moment.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
</main>

<style>
/* Bouton retour */
.btn-back-home {
    display: inline-block;
    background: #e8f4fd;
    color: #0d6efd;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 16px;
    text-decoration: none;
}

/* Section */
.organismes-section {
    padding: 60px 20px 80px;
    background: #f8f9fa;
    min-height: 80vh;
}

.section-header {
    text-align: center;
    margin-bottom: 48px;
}

.section-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 12px;
}

.section-header p {
    font-size: 1.1rem;
    color: #5a5a72;
}

.badge-section {
    display: inline-block;
    background: #e8f4fd;
    color: #0d6efd;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 12px;
}

/* Grid */
.organismes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 28px;
}

/* Card */
.organisme-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
}

.organisme-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0,0,0,0.12);
}

.organisme-photo {
    aspect-ratio: 16/10;
    background: linear-gradient(135deg, #e8f4fd 0%, #d4e8f7 100%);
    display: flex;
    align-items: center;
    justify-content: center;
}

.organisme-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.organisme-placeholder {
    color: #5a5a72;
    font-size: 4rem;
    opacity: 0.5;
}

.organisme-body {
    padding: 24px;
}

.organisme-body h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 8px;
}

.organisme-type {
    display: inline-block;
    font-size: 0.8rem;
    color: #0d6efd;
    font-weight: 600;
    margin-bottom: 10px;
}

.organisme-description {
    font-size: 0.95rem;
    color: #5a5a72;
    line-height: 1.5;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.organisme-ville, .organisme-langue, .organisme-frais, .opportunites {
    font-size: 0.9rem;
    color: #5a5a72;
    margin: 2px 0;
    display: flex;
    align-items: center;
    gap: 6px;
}

.organisme-status.active { color: #2e7d32; font-weight: 600; }
.organisme-status.inactive { color: #c62828; font-weight: 600; }

.organisme-footer {
    padding: 0 24px 24px;
}

.btn-visiter-site {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    color: #0d6efd;
    font-weight: 600;
    text-decoration: none;
    padding: 8px 16px;
    background: #e8f4fd;
    border-radius: 8px;
    transition: all 0.2s;
}

.btn-visiter-site:hover {
    background: #0d6efd !important;
    color: white !important;
}

/* No organismes */
.no-organismes {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: #5a5a72;
}

.no-organismes i {
    font-size: 4rem;
    opacity: 0.4;
    margin-bottom: 16px;
}

/* Responsive */
@media (max-width: 768px) {
    .organismes-grid { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block footer %}
<footer class="main-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-logo">
        <img src="{{ asset('assets/images/logo1.png') }}" alt="LearnFlex+ Logo" class="footer-logo-img">
        <span>LearnFlex+</span>
      </div>
      <div class="footer-slogan">
        <p>Apprends malin, ton bac en main</p>
      </div>
      <div class="footer-social">
        <a href="#"><i class="fab fa-facebook-f"></i></a>
        <a href="#"><i class="fab fa-twitter"></i></a>
        <a href="#"><i class="fab fa-instagram"></i></a>
        <a href="#"><i class="fab fa-linkedin-in"></i></a>
      </div>
    </div>

    <div class="footer-middle">
      <div class="footer-column">
        <h4>Services</h4>
        <ul>
          <li><a href="#">Cours</a></li>
          <li><a href="#">Quiz & Evaluations</a></li>
          <li><a href="#">Forum</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h4>À propos</h4>
        <ul>
          <li><a href="#">Notre mission</a></li>
          <li><a href="#">Orientation</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h4>Légal</h4>
        <ul>
          <li><a href="#">Conditions d'utilisation</a></li>
          <li><a href="#">Politique de confidentialité</a></li>
          <li><a href="#">Cookies</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h4>Contact</h4>
        <ul>
          <li><i class="fas fa-map-marker-alt"></i> 123 Avenue Habib Bourguiba, Tunis</li>
          <li><i class="fas fa-phone"></i> +216 71 123 456</li>
          <li><i class="fas fa-envelope"></i> contact@learnflexplus.com</li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; 2026 LearnFlex+. Tous droits réservés.</p>
    </div>
  </div>
</footer>
{% endblock %}

{% block javascripts %}
<script>
  document.querySelector('.mobile-menu-btn')?.addEventListener('click', function() {
    document.querySelector('.main-nav').classList.toggle('active');
  });
</script>
{% endblock %}
